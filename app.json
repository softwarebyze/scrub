{
  "expo": {
    "icon": "https://storage.googleapis.com/expo-agent-images-production/production/53a0adfc-d6e2-4848-9e0f-22cbfc75c655/019efd74-8404-7a4c-89d1-2b5a8061aabf/c9175438-ee0f-4c7b-8111-dc821c5c3f36",
    "orientation": "default",
    "scheme": "scrub",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "web": {
      "output": "server",
      "favicon": "https://storage.googleapis.com/expo-agent-images-production/production/53a0adfc-d6e2-4848-9e0f-22cbfc75c655/019efd74-8404-7a4c-89d1-2b5a8061aabf/c9175438-ee0f-4c7b-8111-dc821c5c3f36"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "https://storage.googleapis.com/expo-agent-images-production/production/53a0adfc-d6e2-4848-9e0f-22cbfc75c655/019efd74-8404-7a4c-89d1-2b5a8061aabf/c9175438-ee0f-4c7b-8111-dc821c5c3f36",
        "backgroundColor": "#000000"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "mimeType": "video/*"
            }
          ],
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ]
        },
        {
          "action": "SEND",
          "data": [
            {
              "mimeType": "video/*"
            }
          ],
          "category": [
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "infoPlist": {
        "LSSupportsOpeningDocumentsInPlace": true,
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Video",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": [
              "public.movie",
              "public.video",
              "public.mpeg-4",
              "com.apple.quicktime-movie"
            ]
          }
        ]
      }
    },
    "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      "expo-font",
      "expo-image",
      "expo-router",
      "expo-web-browser",
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Scrub to access your videos to scrub through them."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "18.5"
          },
          "android": {
            "minSdkVersion": 28,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "https://storage.googleapis.com/expo-agent-images-production/production/53a0adfc-d6e2-4848-9e0f-22cbfc75c655/019efd74-8404-7a4c-89d1-2b5a8061aabf/c9175438-ee0f-4c7b-8111-dc821c5c3f36",
          "backgroundColor": "#000000",
          "imageWidth": 160,
          "resizeMode": "contain",
          "dark": {
            "image": "https://storage.googleapis.com/expo-agent-images-production/production/53a0adfc-d6e2-4848-9e0f-22cbfc75c655/019efd74-8404-7a4c-89d1-2b5a8061aabf/c9175438-ee0f-4c7b-8111-dc821c5c3f36",
            "backgroundColor": "#000000",
            "imageWidth": 160,
            "resizeMode": "contain"
          }
        }
      ],
      "expo-status-bar"
    ],
    "name": "Scrub",
    "owner": "zackebenfeld",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ecea2033-e306-4070-bf58-7d4728087c3b"
      }
    }
  }
}
